# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

# Frontend (Next.js) - Public keys only
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Modal API Endpoint
# After deploying api_endpoints.py, get the URL from Modal dashboard
# Example: https://your-workspace--ml-agent-swarm-api.modal.run
NEXT_PUBLIC_MODAL_WEBHOOK_URL=your_modal_api_url

# Backend (Modal) - Service role key for server-side operations
# WARNING: Never expose this key to the frontend!
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Local launcher service URL (Option 2 architecture)
DASHBOARD_LAUNCHER_URL=http://127.0.0.1:8001/start-run
