MODAL_APP_NAME=ml-agent-swarm
MODAL_VOLUME_NAME=ml-agent-swarm-data
MODAL_ENVIRONMENT=main

LLM_MODEL_PRIMARY=Qwen/Qwen2.5-32B-Instruct-AWQ
LLM_QUANTIZATION=awq
LLM_GPU=H100
IMPL_GPU=H100

PLAN_TIMEOUT_SECONDS=600
TRAIN_TIMEOUT_SECONDS=1200
TUNING_TIMEOUT_SECONDS=900
LLM_STARTUP_TIMEOUT_SECONDS=1800

MAX_APPROACHES=5
MAX_PARALLEL_AGENTS=4
MAX_TUNING_ITERATIONS=3
LLM_CONCURRENT_REQUESTS=15
MAX_RUN_BUDGET_USD=50

DEFAULT_PRIMARY_METRIC=accuracy
EXPERIMENT_TRACKING=none
