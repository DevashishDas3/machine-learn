# Modal Agent Swarm Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration (for backend updates)
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Modal Configuration (optional - Modal CLI handles auth)
# MODAL_TOKEN_ID=your_modal_token_id
# MODAL_TOKEN_SECRET=your_modal_token_secret
